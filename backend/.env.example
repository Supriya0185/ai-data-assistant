# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── AI Provider ───────────────────────────────────────────────
# Choose: groq (free, fast) or claude (best quality)
AI_PROVIDER=groq

# Groq API key — free at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Groq model (optional — default: llama-3.3-70b-versatile)
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude API (optional — only needed if AI_PROVIDER=claude)
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Claude model (optional — default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── File uploads ──────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# ── PostgreSQL (Phase 3 — not needed yet) ────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/datapilot
